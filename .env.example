# CogMem environment variables
# Copy this file to .env and edit values before docker compose run.

# Runtime API configuration
COGMEM_API_HOST=0.0.0.0
COGMEM_API_PORT=8888
COGMEM_API_LOG_LEVEL=info
COGMEM_API_DATABASE_SCHEMA=public
COGMEM_API_DATABASE_URL=pg0
COGMEM_API_DB_POOL_MIN_SIZE=2
COGMEM_API_DB_POOL_MAX_SIZE=10

# LLM configuration
COGMEM_API_LLM_PROVIDER=openai
COGMEM_API_LLM_API_KEY=your-api-key-here
COGMEM_API_LLM_MODEL=gpt-4o-mini
COGMEM_API_LLM_BASE_URL=
COGMEM_API_LLM_TIMEOUT=120
COGMEM_API_RETAIN_LLM_TIMEOUT=120
COGMEM_API_REFLECT_LLM_TIMEOUT=120

# Retain prompt path knobs (B1 contract)
COGMEM_API_RETAIN_MAX_COMPLETION_TOKENS=64000
COGMEM_API_RETAIN_CHUNK_SIZE=3000
COGMEM_API_RETAIN_EXTRACT_CAUSAL_LINKS=true
COGMEM_API_RETAIN_EXTRACTION_MODE=concise
COGMEM_API_RETAIN_MISSION=
COGMEM_API_RETAIN_CUSTOM_INSTRUCTIONS=

# Retrieval knobs
COGMEM_API_RECALL_MAX_CONCURRENT=32
COGMEM_API_GRAPH_RETRIEVER=bfs
COGMEM_API_TEXT_SEARCH_EXTENSION=native
COGMEM_API_MPFP_TOP_K_NEIGHBORS=20
COGMEM_API_BFS_REFRACTORY_STEPS=1
COGMEM_API_BFS_FIRING_QUOTA=2
COGMEM_API_BFS_ACTIVATION_SATURATION=2.0

# Embeddings provider knobs
COGMEM_API_EMBEDDINGS_PROVIDER=local
COGMEM_API_EMBEDDINGS_LOCAL_MODEL=BAAI/bge-small-en-v1.5
COGMEM_API_EMBEDDINGS_OPENAI_MODEL=text-embedding-3-small
COGMEM_API_EMBEDDINGS_OPENAI_BASE_URL=
COGMEM_API_EMBEDDINGS_OPENAI_API_KEY=

# Reranker provider knobs
COGMEM_API_RERANKER_PROVIDER=rrf
COGMEM_API_RERANKER_LOCAL_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
COGMEM_API_RERANKER_TEI_URL=
COGMEM_API_RERANKER_TEI_BATCH_SIZE=128
COGMEM_API_RERANKER_MAX_CANDIDATES=300

# External PostgreSQL compose mode
# Pin a modern version tag (avoid latest).
# Upgrade intentionally by changing this tag.
COGMEM_DB_IMAGE=pgvector/pgvector:pg18
COGMEM_DB_USER=cogmem_user
COGMEM_DB_PASSWORD=change-me
COGMEM_DB_NAME=cogmem_db

# Docker build/runtime toggles
COGMEM_DOCKER_INCLUDE_LOCAL_MODELS=true
COGMEM_DOCKER_PRELOAD_ML_MODELS=false
COGMEM_DOCKER_TORCH_CPU_VERSION=2.11.0
COGMEM_DOCKER_ST_VERSION=5.3.0

HF_TOKEN=your-huggingface-token-here
